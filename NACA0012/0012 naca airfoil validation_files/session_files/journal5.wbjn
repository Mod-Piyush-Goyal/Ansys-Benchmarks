SetScriptVersion(Version="19.3.111")
system1 = GetSystem(Name="FFF")
setup1 = system1.GetContainer(ComponentName="Setup")
fluentLauncherSettings1 = setup1.GetFluentLauncherSettings()
fluentLauncherSettings1.SetEntityProperties(Properties=Set(DisplayMesh=True, EnvPath={}, NumberOfProcessors=7))
setup1.Edit()
fluentLauncherSettings1.SetEntityProperties(Properties=Set(EnvPath={}, RunParallel=False))
setup1.Edit()
Save(Overwrite=True)
